# dashboard URL embedded by the analytics page
# When running Grafana locally you can leave this as is. Adjust when
# the dashboard is hosted elsewhere (eg. in Docker compose the port is
# mapped to 3001 in this project).
VITE_GRAFANA_DASHBOARD_URL=http://localhost:3001/d/rate-limiter-overview/rate-limiter-overview?orgId=1&from=now-15m&to=now&timezone=browser&refresh=5s
